# ============================================================
# Project Voxa — Monorepo Root .gitignore
# ============================================================

# ── Android / Gradle Build Artifacts ──
*.iml
.gradle/
build/
/captures
.externalNativeBuild/
.cxx/

# ── Local machine config (SDK paths, signing keys) ──
local.properties

# ── IDE: Android Studio / IntelliJ ──
.idea/caches/
.idea/libraries/
.idea/modules.xml
.idea/workspace.xml
.idea/navEditor.xml
.idea/assetWizardSettings.xml
.idea/deploymentTargetSelector.xml
.idea/other.xml
*.iws

# ── IDE: VS Code ──
.vscode/

# ── OS Junk ──
.DS_Store
Thumbs.db
desktop.ini

# ── Kotlin / JVM ──
.kotlin/
*.class
*.jar
*.war
*.ear

# ── Secrets & Keys ──
*.jks
*.keystore
google-services.json
firebase-debug.log

# ── AI Model Binaries (track with Git LFS instead) ──
# *.tflite

# ── Python venvs (if Dev A uses Python tooling locally) ──
__pycache__/
*.pyc
.venv/
venv/

# ── Exclude internal documentation ──
Docs/

